# EL-YANIS (Vite + React Router) — obligatoire sur Hostinger/Apache : sans ce fichier, /admin, /properties, etc. = 404.
# Dépôt : copier TOUT le contenu de dist/ ici, y compris ce fichier caché « .htaccess ».
Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  # Ne pas renvoyer l’SPA pour /api ni /uploads : le JSON doit venir d’un vrai reverse proxy, pas d’index.html.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteCond %{REQUEST_URI} !^/uploads/
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires 0
</IfModule>
