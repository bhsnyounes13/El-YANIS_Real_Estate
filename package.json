{
  "name": "elyanis-real-estate",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c magenta,cyan \"npm run dev:api\" \"node scripts/wait-for-api-and-start-vite.mjs\"",
    "dev:web": "vite",
    "dev:api": "tsx watch backend/src/index.ts",
    "dev:full": "npm run dev",
    "build": "vite build && node scripts/write-netlify-dist-redirects.mjs",
    "prebuild:api": "prisma generate",
    "build:api": "tsc -p backend/tsconfig.json",
    "build:railway-root-entry": "node scripts/write-railway-root-entry.mjs",
    "build:production": "npm run build && npm run build:api && npm run build:railway-root-entry",
    "prestart": "npm run prisma:generate",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "start": "node scripts/ensure-prisma-schema.mjs && node backend/dist/index.js",
    "seed:admin": "node scripts/seed-admin.js",
    "start:api": "node backend/dist/index.js",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "ci": "npm run lint && npm run test && npm run build:production && npm run typecheck:backend",
    "typecheck:backend": "tsc -p backend/tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "export:redesign": "node scripts/export-redesign-pack.mjs",
    "postinstall": "prisma generate --schema backend/prisma/schema.prisma",
    "db:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema backend/prisma/schema.prisma",
    "db:push": "prisma db push --schema backend/prisma/schema.prisma",
    "db:push:safe": "node scripts/assert-database.mjs && prisma db push --schema backend/prisma/schema.prisma",
    "db:seed": "node scripts/assert-database.mjs && prisma db seed --schema backend/prisma/schema.prisma",
    "db:start:docker": "docker compose up -d",
    "db:start": "npm run db:start:docker",
    "db:wait": "node scripts/db-wait.mjs",
    "db:setup": "npm run db:wait && npm run db:push:safe && npm run db:seed",
    "db:setup:docker": "npm run db:start:docker && npm run db:wait && npm run db:push:safe && npm run db:seed",
    "admin:upsert": "node scripts/assert-database.mjs && node scripts/upsert-bootstrap-admin.mjs",
    "db:up": "npm run db:start:docker",
    "db:down": "docker compose down",
    "check:db": "node scripts/check-db.mjs"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma",
    "seed": "tsx backend/prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.0",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/node": "^10.49.0",
    "@sentry/react": "^10.49.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "nodemailer": "^8.0.6",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "5.22.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "react-router-dom": "^7.6.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@exodus/bytes": "^1.15.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.5"
  }
}
