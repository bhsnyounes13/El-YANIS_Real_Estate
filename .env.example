# ═══════════════════════════════════════════════════════════════════════════
# Copier vers `.env` à la racine du projet.
#
# PostgreSQL LOCAL (sans Docker) — workflow typique :
#   1. Installer PostgreSQL, démarrer le service.
#   2. Créer une base (ex. elyanis) et un utilisateur, ou utiliser votre compte admin.
#   3. Adapter DATABASE_URL ci-dessous : user / password / host / port / nom de base.
#   4. npm run db:setup    puis    npm run dev:full
#
# Option Docker (si vous l’utilisez) : voir docker-compose.yml et npm run db:setup:docker
# ═══════════════════════════════════════════════════════════════════════════

# Chaîne Prisma — doit correspondre à VOTRE serveur PostgreSQL local (ou distant).
# Exemple (adapter le mot de passe et le nom de base) :
DATABASE_URL="postgresql://postgres:VOTRE_MOT_DE_PASSE@localhost:5432/elyanis?schema=public"

# Obligatoire pour le backend
JWT_ACCESS_SECRET=change-me-minimum-32-characters-long-secret!!
FRONTEND_ORIGIN=http://localhost:8080

PORT=3001

FORMS_REQUIRE_TURNSTILE=false

# --- Frontend (Vite) ---
# VITE_API_URL=http://localhost:3001
# VITE_TURNSTILE_SITE_KEY=0x4AAAA...
# VITE_AUTH_API_BASE=https://api.example.com
# VITE_BASE_PATH=/

# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_RELEASE=elyanis-web@1.0.0

# --- Production ---
# TURNSTILE_SECRET_KEY=
# LOG_LEVEL=info
# SENTRY_DSN=
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=

# --- Stockage images (admin) : soit disque local (dev), soit S3/R2 ---
# Dev sans cloud — fichiers servis sous http://127.0.0.1:PORT/uploads/...
# STORAGE_LOCAL_ROOT=backend/data/uploads
# Optionnel si l’API n’est pas sur 127.0.0.1:3001 :
# STORAGE_LOCAL_PUBLIC_BASE=http://localhost:3001

# --- Stockage S3/R2 (production ou si vous ne utilisez pas STORAGE_LOCAL_ROOT) ---
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_PUBLIC_URL=
