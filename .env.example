# ═══════════════════════════════════════════════════════════════════════════
# EL-YANIS — variables d’environnement (exemple, sans secrets réels)
#
# Copier vers `.env` à la racine du dépôt (à côté de package.json).
# Prisma lit `DATABASE_URL` depuis ce fichier (ou l’environnement) via
# `backend/prisma/schema.prisma` → datasource `db`.
#
# Développement local : PostgreSQL + `npm run db:push` ou `db:setup`.
# Production : renseigner NODE_ENV=production et les clés listées ci-dessous.
# ═══════════════════════════════════════════════════════════════════════════

# ---------------------------------------------------------------------------
# Prisma / PostgreSQL (obligatoire)
# ---------------------------------------------------------------------------
# Chaîne de connexion PostgreSQL (même format pour `prisma migrate`, `db push`, l’API).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# Délai max (ms) pour la première connexion Prisma au démarrage (évite un blocage infini si le réseau/SSL bloque). Défaut : 30000.
# DB_CONNECT_TIMEOUT_MS=30000

# Si vous ajoutez `directUrl = env("DIRECT_URL")` dans schema.prisma (ex. pooler PgBouncer),
# décommentez et renseignez une URL directe vers Postgres pour les migrations :
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# ---------------------------------------------------------------------------
# API Node (déploiement)
# ---------------------------------------------------------------------------
# production | development | test
NODE_ENV=development

# Port HTTP de l’API (Render, VPS, etc. fournissent souvent PORT automatiquement).
# Défaut applicatif si absent : 3000
PORT=3000

# Monolithe (même service Node) : servir le dossier dist/ après build:production (voir render.yaml).
# Laisser absent ou false pour n’exposer que l’API (front hébergé ailleurs).
# SERVE_SPA=true

# ---------------------------------------------------------------------------
# Obligatoires au démarrage de l’API (dev et production)
# ---------------------------------------------------------------------------
# Secret de signature JWT : minimum 32 caractères ; utilisez une valeur aléatoire forte en prod.
JWT_ACCESS_SECRET=change-me-minimum-32-characters-long-secret!!

# Origine exacte du frontend (CORS / cookies). Une seule URL, sans slash final.
# Dev : http://localhost:8080
# Prod : https://votredomaine.com
FRONTEND_ORIGIN=http://localhost:8080

# ---------------------------------------------------------------------------
# Production uniquement (validation au démarrage)
# ---------------------------------------------------------------------------
# Clé secrète Cloudflare Turnstile (obligatoire si NODE_ENV=production).
# TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Turnstile / formulaires (développement)
# ---------------------------------------------------------------------------
# false = ne pas exiger Turnstile même si une clé secrète est présente (cas rare).
FORMS_REQUIRE_TURNSTILE=false

# ---------------------------------------------------------------------------
# Auth — optionnel (valeurs par défaut dans le code si non défini)
# ---------------------------------------------------------------------------
# JWT_ACCESS_EXPIRES=15m
# JWT_REFRESH_DAYS=7
# BCRYPT_ROUNDS=12
# REFRESH_COOKIE_NAME=ely_refresh

# ---------------------------------------------------------------------------
# Compte admin initial (optionnel, une fois au premier démarrage si la base est vide)
# ---------------------------------------------------------------------------
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=MotDePasseFortAChanger

# ---------------------------------------------------------------------------
# Journaux et monitoring (backend)
# ---------------------------------------------------------------------------
# LOG_LEVEL=info
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_RELEASE=elyanis-api@1.0.0

# ---------------------------------------------------------------------------
# Stockage fichiers images (admin) — disque local OU S3-compatible
# ---------------------------------------------------------------------------
# Dev : servir sous /uploads depuis le disque
# STORAGE_LOCAL_ROOT=backend/data/uploads
# URL publique de base si l’API n’est pas en localhost (prod avec Nginx, etc.) :
# STORAGE_LOCAL_PUBLIC_BASE=https://votredomaine.com

# Cloud (AWS S3, Cloudflare R2, MinIO…) — tout commenter si vous utilisez uniquement le disque
# STORAGE_BUCKET=
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_PUBLIC_URL=
# STORAGE_FORCE_PATH_STYLE=false

# ---------------------------------------------------------------------------
# Frontend (Vite) — à définir au moment du build (CI / hébergeur), pas forcément dans .env local API
# ---------------------------------------------------------------------------
# VITE_API_URL=http://localhost:3000
# VITE_AUTH_API_BASE=https://api.example.com
# VITE_BASE_PATH=/
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAAABBBBBBBBBBBBBBBBCCCCCCCC
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_RELEASE=elyanis-web@1.0.0

# Build Netlify uniquement : proxy /api vers le backend (voir scripts/write-netlify-dist-redirects.mjs)
# NETLIFY_API_PROXY_TARGET=https://api.votredomaine.com
